{% extends 'base.html.twig' %}

{% block title %}Accueil | Tech Flow{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 flex flex-col">

    

    {# --- HERO BANNER --- #}
    <div class="relative bg-gray-900 overflow-hidden">
        <div class="max-w-7xl mx-auto">
            <div class="relative z-10 pb-8 bg-gray-900 sm:pb-16 md:pb-20 lg:max-w-2xl lg:w-full lg:pb-28 xl:pb-32 pt-20 px-4 sm:px-6 lg:px-8">
                <main class="mx-auto max-w-7xl sm:mt-12 md:mt-16 lg:mt-20 xl:mt-28">
                    <div class="sm:text-center lg:text-left">
                        <h1 class="text-4xl tracking-tight font-extrabold text-white sm:text-5xl md:text-6xl">
                            <span class="block xl:inline">L'équipement des</span>
                            <span class="block text-blue-500">vrais professionnels.</span>
                        </h1>
                        <p class="mt-3 text-base text-gray-400 sm:mt-5 sm:text-lg sm:max-w-xl sm:mx-auto md:mt-5 md:text-xl lg:mx-0">
                            Découvrez notre sélection de matériel informatique haut de gamme. Conçu pour la performance, la fiabilité et repousser vos limites.
                        </p>
                        <div class="mt-5 sm:mt-8 sm:flex sm:justify-center lg:justify-start">
                            <div class="rounded-md shadow">
                                <a href="{{ path('app_product_index') }}" class="w-full flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 md:py-4 md:text-lg transition-colors">
                                    Voir le catalogue
                                </a>
                            </div>
                        </div>
                    </div>
                </main>
            </div>
        </div>
        {# Image de fond décorative (facultative) #}
        <div class="lg:absolute lg:inset-y-0 lg:right-0 lg:w-1/2 bg-gray-800 border-l border-gray-700 flex items-center justify-center">
            <span class="text-gray-600 text-2xl font-bold uppercase tracking-widest opacity-20 transform -rotate-12">Tech Flow / Setup</span>
        </div>
    </div>

    {# --- SECTION NOUVEAUTÉS --- #}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="flex justify-between items-end mb-8">
            <h2 class="text-2xl font-bold text-gray-900 tracking-tight">Derniers arrivages</h2>
            <a href="{{ path('app_product_index') }}" class="text-sm font-medium text-blue-600 hover:text-blue-500">Tout voir <span aria-hidden="true">&rarr;</span></a>
        </div>

        {# On réutilise la structure de ta grille de catalogue #}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {% for product in products %}
                {# Ta carte produit ici (tu peux copier celle de ton product/index.html.twig) #}
                <div class="bg-white border border-gray-100 rounded-lg shadow-sm flex flex-col group p-4">
                    <div class="text-sm font-bold text-gray-900 truncate">{{ product.name }}</div>
                    <div class="text-blue-600 font-bold mt-2">{{ (product.price / 100)|number_format(2, ',', ' ') }}€</div>
                    <a href="{{ path('app_product_show', { slug: product.slug }) }}" class="mt-4 text-center bg-black text-white text-xs font-bold py-2 rounded-lg hover:bg-gray-800 transition-colors">Voir</a>
                </div>
            {% else %}
                <p class="text-gray-500 col-span-4 text-center">Aucun produit pour le moment.</p>
            {% endfor %}
        </div>
    </div>

</div>
{% endblock %}