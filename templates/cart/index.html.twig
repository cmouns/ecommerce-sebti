{% extends 'base.html.twig' %}

{% block title %}Mon Panier | Tech Flow{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 py-12">
    <div class="max-w-5xl mx-auto px-4">
        <a href=""></a>
        <h1 class="text-3xl font-extrabold text-gray-900 mb-8">Votre Panier</h1>

        {% if items|length > 0 %}
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="lg:col-span-2 space-y-4">
                    {% for item in items %}
                        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 flex items-center justify-between">
                            <div class="flex flex-col">
                                <span class="text-sm font-bold text-blue-600">{{ item.product.category.name }}</span>
                                <h2 class="text-lg font-bold text-gray-900">{{ item.product.name }}</h2>
                            </div>

                            {# Dropdown #}
                            <form action="{{ path('app_cart_update', {id: item.product.id}) }}" method="POST">
                                <select name="quantity" onchange="this.form.submit()" class="border rounded-lg p-2 bg-gray-50 text-sm font-bold focus:ring-2 focus:ring-black outline-none cursor-pointer">
                                    <option value="0">0 (Supprimer)</option>
                                    {% for i in 1.. item.quantity %}
                                        <option value="{{ i }}" {{ item.quantity == i ? 'selected' : '' }}>{{ i }}</option>
                                    {% endfor %}
                                    {% if item.quantity > 10 %}
                                        <option value="{{ item.quantity }}" selected>{{ item.quantity }}</option>
                                    {% endif %}
                                </select>
                            </form>

                            <div class="text-right">
                                <p class="text-xl font-black text-black">{{ ((item.product.price * item.quantity) / 100)|number_format(2, ',', ' ') }}€</p>
                                <a href="{{ path('app_cart_remove', {id: item.product.id}) }}" class="text-xs text-red-500 hover:underline">Supprimer</a>
                            </div>
                        </div>
                    {% endfor %}
                    <a href="{{ path('app_cart_empty') }}" class="inline-block text-sm text-red-500 hover:underline mt-4">Vider entièrement le panier</a>
                </div>

                <div class="bg-gray-900 p-8 rounded-2xl text-white h-fit shadow-xl">
                    <h3 class="text-xl font-bold mb-6 border-b border-gray-800 pb-4">RÉSUMÉ</h3>
                    <div class="flex justify-between text-2xl font-black mb-8">
                        <span>TOTAL</span>
                        <span class="text-blue-400">{{ (total / 100)|number_format(2, ',', ' ') }}€</span>
                    </div>
                    <button class="w-full py-4 bg-blue-600 hover:bg-blue-700 rounded-xl font-bold transition-all shadow-lg hover:shadow-blue-500/30">
                        VALIDER LA COMMANDE
                    </button>
                </div>
            </div>
        {% else %}
            <div class="text-center py-20 bg-white rounded-2xl border border-gray-200">
                <p class="text-gray-500 mb-6">Votre panier est vide.</p>
                <a href="{{ path('app_product_index') }}" class="bg-black text-white px-8 py-3 rounded-lg font-bold">Retour à la boutique</a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}