{% extends 'base.html.twig' %}

{% block title %}Catalogue Tech-Flow | Matériel Informatique Professionnel{% endblock %}

{% block body %}
<main class="min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        {# --- En-tête --- #}
        <header class="flex flex-col items-center md:block mb-10 pb-6 border-b border-gray-200">
            <h1 class="text-3xl font-bold text-gray-900 tracking-tight">
                Tous les produits
            </h1>
            <p class="text-sm text-gray-700 mt-2" aria-live="polite">
                {{ products|length }} produits trouvés
            </p>
        </header>

        {# --- Grille --- #}
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-2 md:gap-x-6 gap-y-5 md:gap-y-10">
            {% for product in products %}
                {# --- Carte Produit --- #}
                <article class="bg-white border border-gray-100 rounded-lg shadow-sm hover:shadow-md transition-shadow duration-200 flex flex-col group">
                    
                    {# --- Zone Image --- #}
                    <div class="aspect-4/3 w-full rounded-t-lg bg-white flex items-center justify-center overflow-hidden p-4 relative">
                        <img src="{{ asset('uploads/images/ecran.jpg') }}" 
                            alt="Photo du produit : {{ product.name }}" 
                            class="object-contain w-full h-full mix-blend-multiply transform group-hover:scale-105 transition-transform duration-500 ease-out">
                    </div>
                    
                    {# --- Contenu de la carte --- #}
                    <div class="p-4 flex flex-col grow">
                        {# --- Catégorie --- #}
                        <span class="text-xs font-medium text-blue-800 bg-blue-50 px-1.5 py-0.5 rounded-full self-start mb-2">
                            {{ product.category.name }}
                        </span>
                        
                        {# --- Titre --- #}
                        <h2 class="text-md font-semibold text-gray-900 hover:text-blue-800 mb-1">
                            {{ product.name }}
                        </h2>
                        
                        {# --- Description --- #}
                        <p class="text-xs text-gray-700 line-clamp-2 mb-3">
                            {{ product.description }}
                        </p>
                        
                        {# --- Prix et stock --- #}
                        <div class="mt-auto pt-3 border-t border-gray-100">
                            <div class="flex justify-between items-baseline mb-3">
                                {# --- Prix --- #}
                                <span class="text-lg font-bold text-black" aria-label="Prix : {{ (product.price / 100)|number_format(2,',',' ')}} euros">
                                    {{ (product.price / 100)|number_format(2,',',' ')}}€
                                </span>                                
                                {# --- Stock --- #}
                                <span class="text-xs {{ product.stock > 0 ? 'text-green-800' : 'text-red-700' }} font-bold">
                                    {{ product.stock > 0 ? 'En stock' : 'Rupture' }}
                                </span>
                            </div>

                            {# --- Bouton de redirection --- #}
                            <a href="{{ path('app_product_show', { slug: product.slug }) }}" 
                               aria-label="Voir les détails du produit : {{ product.name }}"
                               class="block text-center bg-black hover:bg-gray-800 focus:ring-4 focus:ring-gray-300 text-white rounded-xl py-2.5 px-4 text-sm font-semibold transition-colors outline-none">
                                Voir le produit
                            </a>
                        </div>
                    </div>
                </article>
            {% else %}
                {# Si aucun produit #}
                <div class="col-span-full text-center py-20 bg-white rounded-lg border border-gray-200 shadow-inner">
                    <p class="text-gray-700 font-medium">Aucun produit disponible actuellement.</p>
                </div>
            {% endfor %}
        </div>
    </div>
</main>
{% endblock %}