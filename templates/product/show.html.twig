{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} | Tech-Flow{% endblock %}

{% block body %}
<main class="bg-white min-h-screen py-8 overflow-x-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        {# ---  Fil d'Ariane --- #}
        <nav aria-label="Fil d'Ariane" class="flex items-center text-sm text-gray-700 mb-8 font-medium">
            <a href="{{ path('app_product_index') }}" class="hover:text-black hover:underline transition-colors flex items-center gap-1 text-red-700">
                 Retour
            </a>
            <span class="mx-4 text-gray-900 font-bold" aria-current="page"> {{ product.category.name }}</span>
            <span class="mx-2 text-gray-500" aria-hidden="true">&gt;</span>
            <span class="text-gray-600 truncate max-w-[200px] md:max-w-none">{{ product.name }}</span>
        </nav>

        {# --- 2. Conteneur Principal --- #}
        <div class="flex flex-col md:flex-row gap-10">

            {# --- image : gauche  --- #}
            <div class="w-full md:w-3/5 flex flex-col-reverse md:flex-row gap-4">
                
                {# TODO: Rendre la galerie de miniatures dynamique quand l'entité Product aura plusieurs images #}
                <div class="flex flex-row md:flex-col gap-3 w-full md:w-20 overflow-x-auto md:overflow-hidden pb-2 md:pb-0">
                    {# Ajout d'un aria-label sur le bouton de miniature #}
                    <button aria-label="Afficher la première image de {{ product.name }}" class="border border-black rounded shrink-0 w-20 h-20 md:w-full md:h-auto md:aspect-square p-1 focus:ring-4 focus:ring-gray-300 outline-none">
                        <img src="{{ asset('uploads/images/ecran.jpg') }}" class="object-contain w-full h-full mix-blend-multiply" alt="">
                    </button>
                </div>

                <div class="flex-1 bg-white flex items-center justify-center relative p-4">
                    {# Ajout de contexte à l'attribut alt #}
                    <img src="{{ asset('uploads/images/ecran.jpg') }}" 
                         alt="Photo principale du produit : {{ product.name }}" 
                         class="object-contain w-full max-h-[500px] mix-blend-multiply drop-shadow-sm">
                </div>
            </div>

            {# --- droite : informations --- #}
            <div class="w-full md:w-2/5 flex flex-col">
                <h1 class="text-2xl font-bold text-gray-900 leading-snug mb-2 uppercase tracking-tight">
                    {{ product.name }}
                </h1>

                {# prix  #}
                <div class="flex items-end gap-3 mb-6">
                    {# Ajout de aria-label pour la lecture du prix #}
                    <span class="text-2xl font-bold text-black" aria-label="Prix : {{ (product.price / 100)|number_format(2, ',', ' ') }} euros">
                        {{ (product.price / 100)|number_format(2, ',', ' ') }}€
                    </span>
                </div>

                {# Formulaire ajout panier #}
                <form action="#" method="POST" class="mb-4">
                    {# Sélection Quantité Dynamique (Si en stock) #}
                    {% if product.stock > 0 %}
                        <div class="mb-4">
                            <label for="quantity" class="block text-sm font-bold text-gray-900 mb-2">Quantité:</label>
                            <select id="quantity" name="quantity" class="border border-gray-300 rounded p-2.5 w-24 bg-white text-sm focus:border-black focus:ring-2 outline-none">
                                {% set max_qty = min(99, product.stock) %}
                                {% for i in 1..max_qty %}
                                    <option value="{{ i }}">{{ i }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        
                        <p class="text-sm text-gray-900 font-bold mb-6">
                            Disponibilité: <span class="text-[#008A00] font-normal">En stock</span>
                        </p>
                    {% else %}
                        {# Ajout d'un rôle d'alerte pour les ruptures de stock #}
                        <p role="alert" class="text-sm text-red-700 font-bold mb-6">
                            Cet article est actuellement en rupture de stock.
                        </p>
                    {% endif %}

                        {# Boutons panier  #}
                    <button type="submit" class="w-1/2 font-bold py-3.5 px-4 rounded transition-colors text-sm focus:ring-4 focus:ring-gray-400 outline-none
                            {{ product.stock > 0 ? 'bg-black hover:bg-gray-700 text-white' : 'bg-gray-300 text-gray-500 cursor-not-allowed' }}"
                            {{ product.stock == 0 ? 'disabled' : '' }}>
                        Ajouter au panier
                    </button>
                </form>

                {# Description #}
                <div class="border-t border-gray-200 pt-6 mt-2">
                    <h2 class="text-sm font-bold mb-3 uppercase tracking-wider text-gray-900">Description</h2> 
                    <p class="text-sm text-gray-700 leading-relaxed"> 
                        {{ product.description }}
                    </p>
                </div>

            </div>
        </div>
    </div>
</main>
{% endblock %}